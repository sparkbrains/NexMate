APP_ENV=local
OPENROUTER_API_KEY=your_key_here
GENERATION_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
APP_REFERER=http://localhost:8000
APP_TITLE=nextmate

# PostgreSQL for NextMate.
# Docker Compose runs a dedicated Postgres container for this app.
# Inside Docker, connect to the service name `postgres`.
# From your host machine, the same database is exposed on port 5433.
DATABASE_URL=postgresql://nextmate_user:nextmate_password@postgres:5432/nextmate

MEMORY_WINDOW=20
STREAM_CHUNK_SIZE=1
STREAM_DELAY_SECONDS=0.03
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SEED_DUMMY_USERS=true
DUMMY_USERS=demo@nextmate.local:demo123,qa@nextmate.local:demo123
