APP_ENV=local

GROQ_API_KEY=
GENERATION_MODEL=llama-3.3-70b-versatile
#OPENROUTER_API_KEY=

#GENERATION_MODEL=arcee-ai/trinity-large-preview:free
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
APP_REFERER=http://localhost:8000
APP_TITLE=nextmate

# Docker Compose Postgres for NextMate.
DATABASE_URL=postgresql://nextmate_user:nextmate_password@localhost:5433/nextmate

MEMORY_WINDOW=20
STREAM_CHUNK_SIZE=1
STREAM_DELAY_SECONDS=0.03
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local-only seed users for quick testing.
SEED_DUMMY_USERS=true
DUMMY_USERS=demo@nextmate.local:demo123,qa@nextmate.local:demo123
